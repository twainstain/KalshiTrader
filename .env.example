# ---- Kalshi API ----
# Create demo key pair at demo.kalshi.co/account/profile (Phase 1)
# or kalshi.com/account/profile (Phase 2 prod).
KALSHI_API_KEY_ID=
# Absolute path to RSA private-key PEM. Store OUTSIDE this repo.
KALSHI_PRIVATE_KEY_PATH=
# "demo" or "prod". Phase 1 must stay on "demo".
KALSHI_ENV=demo

# ---- CF Benchmarks (licensed reference feed, P2 only) ----
# Leave blank in Phase 1 — BasketReferenceSource is used instead.
CF_BENCHMARKS_API_KEY=

# ---- Persistence ----
# SQLite (dev default) or Postgres DSN (prod).
# Examples:
#   sqlite:///data/kalshi.db
#   postgresql://user:pass@localhost:5432/kalshi
DATABASE_URL=sqlite:///data/kalshi.db

# --- Dashboard Auth (HTTP Basic) ---
DASHBOARD_USER=admin
DASHBOARD_PASS='adminTest'

# --- Bot Defaults (override with CLI flags) ---
BOT_CONFIG=config/example_config.json


# --- Telegram Alerts ---
# 1. Message @BotFather on Telegram → create bot → get token
# 2. Start chat with bot → GET https://api.telegram.org/bot<TOKEN>/getUpdates → find chat_id
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_CHAT_ID=987654321

# --- Discord Alerts ---
# Channel Settings → Integrations → Webhooks → copy URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/1493365174625632256/9Tvf_5E-h6MIlEB8DyVxJ0Gkwyh3xkvMOc-Z4xibbnMKoKJJ1e90OGTDQZO_22uAileQ

# --- Gmail Alerts ---
